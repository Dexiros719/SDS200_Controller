<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <FrameLayout
            android:id="@+id/toolbar_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#222222"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/top_app_bar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIcon="@drawable/ic_menu_24" />
        </FrameLayout>

        <!-- Display Area -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/display_screen"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@+id/toolbar_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/keyboard_layout"
            app:layout_constraintVertical_weight="1.2">

            <TextView
                android:id="@+id/v_text_view"
                style="@style/ScannerDisplayText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:text="V:---"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/s_text_view"
                style="@style/ScannerDisplayText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="S:---"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="@+id/v_text_view"
                app:layout_constraintStart_toEndOf="@+id/v_text_view"
                app:layout_constraintTop_toTopOf="@+id/v_text_view" />

            <TextView
                android:id="@+id/date_time_text_view"
                style="@style/ScannerDisplayText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="---"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="@+id/s_text_view"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/s_text_view" />

            <View
                android:id="@+id/divider1"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="#FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/v_text_view" />

            <TextView
                android:id="@+id/status_message_text_view"
                style="@style/ScannerDisplayText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Scanner Unavailable"
                android:textColor="#FF0000"
                android:textSize="24sp"
                android:gravity="center"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@+id/divider1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/normal_display_container"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@+id/divider1"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/system_name_text_view"
                    style="@style/ScannerDisplayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:text="---"
                    android:textColor="#FF0000"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/divider2"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:background="#FF0000"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/system_name_text_view" />

                <TextView
                    android:id="@+id/dept_name_text_view"
                    style="@style/ScannerDisplayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:text="---"
                    android:textColor="#FFA500"
                    android:textSize="20sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/divider2" />

                <TextView
                    android:id="@+id/channel_name_text_view"
                    style="@style/ScannerDisplayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="---"
                    android:textColor="#FFA500"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/dept_name_text_view" />

                <View
                    android:id="@+id/divider3"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:background="#FFA500"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/channel_name_text_view" />

                <TextView
                    android:id="@+id/info_area_text_view"
                    style="@style/ScannerDisplayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:text="---"
                    android:textColor="#FFFF00"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/divider3" />

                <View
                    android:id="@+id/divider4"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:background="#FFFF00"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/info_area_text_view" />

                <TextView
                    android:id="@+id/freq_text_view"
                    style="@style/ScannerDisplayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:text="---"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/divider4" />

                <TextView
                    android:id="@+id/svc_type_text_view"
                    style="@style/ScannerDisplayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="---"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/freq_text_view" />

                <TextView
                    android:id="@+id/am_text_view"
                    style="@style/ScannerDisplayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="---"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/svc_type_text_view" />

                <LinearLayout
                    android:id="@+id/bottom_display_buttons"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <TextView
                        android:id="@+id/button_system"
                        style="@style/DisplayButton"
                        android:text="SYSTEM" />

                    <TextView
                        android:id="@+id/button_dept"
                        style="@style/DisplayButton"
                        android:text="DEPT" />

                    <TextView
                        android:id="@+id/button_channel"
                        style="@style/DisplayButton"
                        android:text="CHANNEL" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/keyboard_layout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:padding="2dp"
            android:background="#000000"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/display_screen"
            app:layout_constraintVertical_weight="0.8">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:orientation="vertical">

                <Button
                    android:id="@+id/button_func"
                    style="@style/KeypadButton.Vertical"
                    android:layout_weight="1"
                    android:text="FUNC" />

                <Button
                    android:id="@+id/button_menu"
                    style="@style/KeypadButton.Vertical"
                    android:layout_weight="1"
                    android:text="MENU" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:orientation="vertical">

                <Button
                    android:id="@+id/button_zip"
                    style="@style/KeypadButton.Vertical"
                    android:layout_weight="1"
                    android:text="ZIP\nService" />

                <Button
                    android:id="@+id/button_replay"
                    style="@style/KeypadButton.Vertical"
                    android:layout_weight="1"
                    android:text="Replay\nRecord" />

                <Button
                    android:id="@+id/button_avoid"
                    style="@style/KeypadButton.Vertical"
                    android:layout_weight="1"
                    android:text="AVOID" />

                <Button
                    android:id="@+id/button_rot"
                    style="@style/KeypadButton.Vertical"
                    android:layout_weight="1"
                    android:text="ROT" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/button_1"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="1" />
                        <TextView style="@style/KeypadTextSub" android:text="SRCH1" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_2"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="2" />
                        <TextView style="@style/KeypadTextSub" android:text="SRCH2" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_3"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="3" />
                        <TextView style="@style/KeypadTextSub" android:text="SRCH3" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/button_4"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="4" />
                        <TextView style="@style/KeypadTextSub" android:text="ATT" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_5"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="5" />
                        <TextView style="@style/KeypadTextSub" android:text="DIM" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_6"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="6" />
                        <TextView style="@style/KeypadTextSub" android:text="VX" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/button_7"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="7" />
                        <TextView style="@style/KeypadTextSub" android:text="IFX" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_8"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="8" />
                        <TextView style="@style/KeypadTextSub" android:text="REV" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_9"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="9" />
                        <TextView style="@style/KeypadTextSub" android:text="DISP" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/button_dot"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="." />
                        <TextView style="@style/KeypadTextSub" android:text="NO PRI" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_0"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="0" />
                        <TextView style="@style/KeypadTextSub" android:text="LVL" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/button_e"
                        style="@style/KeypadButtonContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <TextView style="@style/KeypadTextMain" android:text="E" />
                        <TextView style="@style/KeypadTextSub" android:text="YES Q.SRCH" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="false"
        android:background="#CC1A1A1A"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#FFFFFF"
        app:menu="@menu/top_app_bar_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
